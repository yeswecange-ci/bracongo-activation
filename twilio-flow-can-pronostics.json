{
  "description": "CAN 2025 - Pronostics + Inscription auto. Historique au retour, saut de sélection si 1 seul match, clé API.",
  "states": [
    {
      "name": "Trigger",
      "type": "trigger",
      "transitions": [
        {
          "next": "set_phone",
          "event": "incomingMessage"
        },
        {
          "event": "incomingCall"
        },
        {
          "next": "set_phone",
          "event": "incomingConversationMessage"
        },
        {
          "event": "incomingRequest"
        },
        {
          "next": "set_phone",
          "event": "incomingParent"
        }
      ],
      "properties": {
        "offset": {
          "x": 0,
          "y": 0
        }
      }
    },
    {
      "name": "set_phone",
      "type": "set-variables",
      "transitions": [
        {
          "next": "http_check_user",
          "event": "next"
        }
      ],
      "properties": {
        "variables": [
          {
            "type": "string",
            "value": "{{trigger.message.From}}",
            "key": "phone_number"
          },
          {
            "type": "string",
            "value": "REMPLACE_PAR_CAN_API_KEY",
            "key": "api_key"
          }
        ],
        "offset": {
          "x": 350,
          "y": 180
        }
      }
    },
    {
      "name": "http_check_user",
      "type": "make-http-request",
      "transitions": [
        {
          "next": "route_user",
          "event": "success"
        },
        {
          "next": "msg_erreur_api",
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": 350,
          "y": 360
        },
        "method": "POST",
        "content_type": "application/json",
        "add_twilio_auth": false,
        "body": "{\"phone\":\"{{flow.variables.phone_number}}\",\"api_key\":\"{{flow.variables.api_key}}\"}",
        "url": "https://can-wabracongo.ywcdigital.com/api/can/check-user"
      }
    },
    {
      "name": "route_user",
      "type": "split-based-on",
      "transitions": [
        {
          "next": "msg_ask_name",
          "event": "noMatch"
        },
        {
          "next": "http_user_pronos",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Déjà inscrit",
              "arguments": [
                "{{widgets.http_check_user.parsed.status}}"
              ],
              "type": "equal_to",
              "value": "INSCRIT"
            }
          ]
        }
      ],
      "properties": {
        "input": "{{widgets.http_check_user.parsed.status}}",
        "offset": {
          "x": 350,
          "y": 540
        }
      }
    },
    {
      "name": "msg_ask_name",
      "type": "send-and-wait-for-reply",
      "transitions": [
        {
          "next": "set_name",
          "event": "incomingMessage"
        },
        {
          "next": "msg_timeout",
          "event": "timeout"
        },
        {
          "next": "end_success",
          "event": "deliveryFailure"
        }
      ],
      "properties": {
        "offset": {
          "x": 800,
          "y": 740
        },
        "from": "{{flow.channel.address}}",
        "body": "👋 *Bienvenue dans le jeu de pronostics CAN 2025 !*\n\nAvant de jouer, dis-moi simplement ton *prénom* 👇",
        "timeout": "3600"
      }
    },
    {
      "name": "set_name",
      "type": "set-variables",
      "transitions": [
        {
          "next": "http_inscription",
          "event": "next"
        }
      ],
      "properties": {
        "variables": [
          {
            "type": "string",
            "value": "{{widgets.msg_ask_name.inbound.Body}}",
            "key": "user_name"
          }
        ],
        "offset": {
          "x": 800,
          "y": 940
        }
      }
    },
    {
      "name": "http_inscription",
      "type": "make-http-request",
      "transitions": [
        {
          "next": "check_inscription_success",
          "event": "success"
        },
        {
          "next": "msg_erreur_api",
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": 800,
          "y": 1120
        },
        "method": "POST",
        "content_type": "application/json",
        "add_twilio_auth": false,
        "body": "{\"phone\":\"{{flow.variables.phone_number}}\",\"name\":\"{{flow.variables.user_name}}\",\"source_type\":\"DIRECT\",\"source_detail\":\"WHATSAPP\",\"api_key\":\"{{flow.variables.api_key}}\"}",
        "url": "https://can-wabracongo.ywcdigital.com/api/can/inscription"
      }
    },
    {
      "name": "check_inscription_success",
      "type": "split-based-on",
      "transitions": [
        {
          "next": "msg_erreur_api",
          "event": "noMatch"
        },
        {
          "next": "msg_welcome",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Inscription OK",
              "arguments": [
                "{{widgets.http_inscription.parsed.success}}"
              ],
              "type": "equal_to",
              "value": "true"
            }
          ]
        }
      ],
      "properties": {
        "input": "{{widgets.http_inscription.parsed.success}}",
        "offset": {
          "x": 800,
          "y": 1300
        }
      }
    },
    {
      "name": "msg_welcome",
      "type": "send-message",
      "transitions": [
        {
          "next": "http_user_pronos",
          "event": "sent"
        },
        {
          "next": "http_user_pronos",
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": 800,
          "y": 1480
        },
        "from": "{{flow.channel.address}}",
        "to": "{{contact.channel.address}}",
        "body": "✅ *Inscription réussie, {{widgets.http_inscription.parsed.name}} !* 🎉\n\nC'est parti pour ton pronostic 👇"
      }
    },
    {
      "name": "http_user_pronos",
      "type": "make-http-request",
      "transitions": [
        {
          "next": "split_show_historique",
          "event": "success"
        },
        {
          "next": "msg_erreur_api",
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": 350,
          "y": 1680
        },
        "method": "POST",
        "content_type": "application/json",
        "add_twilio_auth": false,
        "body": "{\"phone\":\"{{flow.variables.phone_number}}\",\"api_key\":\"{{flow.variables.api_key}}\"}",
        "url": "https://can-wabracongo.ywcdigital.com/api/can/user-pronostics"
      }
    },
    {
      "name": "split_show_historique",
      "type": "split-based-on",
      "transitions": [
        {
          "next": "split_action",
          "event": "noMatch"
        },
        {
          "next": "msg_historique",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "A des pronostics",
              "arguments": [
                "{{widgets.http_user_pronos.parsed.has_pronostics}}"
              ],
              "type": "equal_to",
              "value": "true"
            }
          ]
        }
      ],
      "properties": {
        "input": "{{widgets.http_user_pronos.parsed.has_pronostics}}",
        "offset": {
          "x": 350,
          "y": 1860
        }
      }
    },
    {
      "name": "msg_historique",
      "type": "send-message",
      "transitions": [
        {
          "next": "split_action",
          "event": "sent"
        },
        {
          "next": "split_action",
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": -100,
          "y": 2060
        },
        "from": "{{flow.channel.address}}",
        "to": "{{contact.channel.address}}",
        "body": "{{widgets.http_user_pronos.parsed.historique_message}}"
      }
    },
    {
      "name": "split_action",
      "type": "split-based-on",
      "transitions": [
        {
          "next": "msg_erreur_api",
          "event": "noMatch"
        },
        {
          "next": "msg_aucun_match_disponible",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Aucun match",
              "arguments": [
                "{{widgets.http_user_pronos.parsed.next_action}}"
              ],
              "type": "equal_to",
              "value": "NO_MATCH"
            }
          ]
        },
        {
          "next": "msg_all_done",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Tout parié",
              "arguments": [
                "{{widgets.http_user_pronos.parsed.next_action}}"
              ],
              "type": "equal_to",
              "value": "ALL_DONE"
            }
          ]
        },
        {
          "next": "set_match_1",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Un seul match",
              "arguments": [
                "{{widgets.http_user_pronos.parsed.next_action}}"
              ],
              "type": "equal_to",
              "value": "SINGLE"
            }
          ]
        },
        {
          "next": "msg_liste_matchs",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Plusieurs matchs",
              "arguments": [
                "{{widgets.http_user_pronos.parsed.next_action}}"
              ],
              "type": "equal_to",
              "value": "MULTIPLE"
            }
          ]
        }
      ],
      "properties": {
        "input": "{{widgets.http_user_pronos.parsed.next_action}}",
        "offset": {
          "x": 350,
          "y": 2260
        }
      }
    },
    {
      "name": "msg_aucun_match_disponible",
      "type": "send-message",
      "transitions": [
        {
          "next": "end_success",
          "event": "sent"
        },
        {
          "next": "end_success",
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": 1100,
          "y": 2460
        },
        "from": "{{flow.channel.address}}",
        "to": "{{contact.channel.address}}",
        "body": "❌ *AUCUN MATCH DISPONIBLE*\n\nIl n'y a aucun match ouvert pour les pronostics en ce moment.\n\n📅 Reviens dès qu'un nouveau match sera programmé.\n\n🍀 À bientôt !"
      }
    },
    {
      "name": "msg_all_done",
      "type": "send-message",
      "transitions": [
        {
          "next": "end_success",
          "event": "sent"
        },
        {
          "next": "end_success",
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": 700,
          "y": 2460
        },
        "from": "{{flow.channel.address}}",
        "to": "{{contact.channel.address}}",
        "body": "✅ *Tu as déjà parié sur tous les matchs disponibles !*\n\n📅 Reviens dès qu'un nouveau match sera ouvert pour pronostiquer.\n\n🍀 Bonne chance pour tes paris en cours !"
      }
    },
    {
      "name": "msg_erreur_api",
      "type": "send-message",
      "transitions": [
        {
          "next": "end_success",
          "event": "sent"
        },
        {
          "next": "end_success",
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": 1450,
          "y": 540
        },
        "from": "{{flow.channel.address}}",
        "message_type": "custom",
        "to": "{{contact.channel.address}}",
        "body": "❌ Une erreur est survenue. Réessaie dans quelques instants."
      }
    },
    {
      "name": "msg_liste_matchs",
      "type": "send-and-wait-for-reply",
      "transitions": [
        {
          "next": "check_choix_match",
          "event": "incomingMessage"
        },
        {
          "next": "msg_timeout",
          "event": "timeout"
        },
        {
          "next": "end_success",
          "event": "deliveryFailure"
        }
      ],
      "properties": {
        "offset": {
          "x": -150,
          "y": 2460
        },
        "from": "{{flow.channel.address}}",
        "body": "{{widgets.http_user_pronos.parsed.remaining_matches_message}}",
        "timeout": "3600"
      }
    },
    {
      "name": "msg_timeout",
      "type": "send-message",
      "transitions": [
        {
          "next": "end_success",
          "event": "sent"
        },
        {
          "next": "end_success",
          "event": "failed"
        }
      ],
      "properties": {
        "offset": {
          "x": -600,
          "y": 2660
        },
        "from": "{{flow.channel.address}}",
        "to": "{{contact.channel.address}}",
        "body": "⏱️ Temps écoulé ! Renvoie un message pour recommencer ton pronostic."
      }
    },
    {
      "name": "check_choix_match",
      "type": "split-based-on",
      "transitions": [
        {
          "next": "msg_choix_invalide",
          "event": "noMatch"
        },
        {
          "next": "set_match_1",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Match 1",
              "arguments": [
                "{{widgets.msg_liste_matchs.inbound.Body}}"
              ],
              "type": "matches_any_of",
              "value": "1"
            }
          ]
        },
        {
          "next": "set_match_2",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Match 2",
              "arguments": [
                "{{widgets.msg_liste_matchs.inbound.Body}}"
              ],
              "type": "matches_any_of",
              "value": "2"
            }
          ]
        },
        {
          "next": "set_match_3",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Match 3",
              "arguments": [
                "{{widgets.msg_liste_matchs.inbound.Body}}"
              ],
              "type": "matches_any_of",
              "value": "3"
            }
          ]
        },
        {
          "next": "set_match_4",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Match 4",
              "arguments": [
                "{{widgets.msg_liste_matchs.inbound.Body}}"
              ],
              "type": "matches_any_of",
              "value": "4"
            }
          ]
        },
        {
          "next": "set_match_5",
          "event": "match",
          "conditions": [
            {
              "friendly_name": "Match 5",
              "arguments": [
                "{{widgets.msg_liste_matchs.inbound.Body}}"
              ],
              "type": "matches_any_of",
              "value": "5"
            }
          ]
        }
      ],
      "properties": {
        "input": "{{widgets.msg_liste_matchs.inbound.Body}}",
        "offset": {
          "x": 0,
          "y": 2660
        }
      }
    },
    {
      "name": "set_match_1",
      "type": "set-variables",
      "transitions": [
        {
          "next": "msg_options_prono",
          "event": "next"
        }
      ],
      "properties": {
        "variables": [
          {
            "type": "string",
            "value": "{{widgets.http_user_pronos.parsed.remaining_matches[0].id}}",
