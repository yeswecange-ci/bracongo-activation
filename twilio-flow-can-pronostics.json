          "y": 2900
        }
      }
    },
    {
      "name": "set_match_3",
      "type": "set-variables",
      "transitions": [
        {
          "next": "msg_options_prono",
          "event": "next"
        }
      ],
      "properties": {
        "variables": [
          {
            "type": "string",
            "value": "{{widgets.http_user_pronos.parsed.remaining_matches[2].id}}",
            "key": "selected_match_id"
          },
          {
            "type": "string",
            "value": "{{widgets.http_user_pronos.parsed.remaining_matches[2].team_a}}",
            "key": "selected_team_a"
          },
