        }
      ],
      "properties": {
        "variables": [
          {
            "type": "string",
            "value": "{{widgets.http_user_pronos.parsed.remaining_matches[3].id}}",
            "key": "selected_match_id"
          },
          {
            "type": "string",
            "value": "{{widgets.http_user_pronos.parsed.remaining_matches[3].team_a}}",
            "key": "selected_team_a"
          },
          {
            "type": "string",
            "value": "{{widgets.http_user_pronos.parsed.remaining_matches[3].team_b}}",
            "key": "selected_team_b"
          }
        ],
        "offset": {
          "x": 400,
          "y": 2900
        }
      }
    },
    {
      "name": "set_match_5",
      "type": "set-variables",
      "transitions": [
        {
          "next": "msg_options_prono",
          "event": "next"
        }
      ],
      "properties": {
        "variables": [
          {
            "type": "string",
            "value": "{{widgets.http_user_pronos.parsed.remaining_matches[4].id}}",
            "key": "selected_match_id"
          },
          {
            "type": "string",
            "value": "{{widgets.http_user_pronos.parsed.remaining_matches[4].team_a}}",
